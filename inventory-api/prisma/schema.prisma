generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]

}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

// Types of actions recorded against an asset
enum AssetActionType {
  REPAIR
  MAINTENANCE
  HIRE
  END_OF_LIFE
  LOST
  STOLEN
  CHECK_IN
  CHECK_OUT
  TRANSFER
  STATUS_CHANGE
}

// Priority for service actions
enum ActionPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model asset_logs {
  id       String    @id @default(dbgenerated("uuid_generate_v4()"))
  asset_id String?
  message  String?
  date     DateTime? @default(now()) @db.Timestamp(6)
  user_id  String?
  assets   assets?   @relation(fields: [asset_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users    users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model asset_types {
  id         String              @id @default(dbgenerated("uuid_generate_v4()"))
  name       String
  image_url  String?
  created_at DateTime            @default(now()) @db.Timestamp(6)
  updated_at DateTime?           @updatedAt
  fields     asset_type_fields[]
  assets     assets[]
}

model assets {
  type_id           String?
  serial_number     String?
  model             String?
  description       String?
  other_id          String?
  assigned_to_id    String?
  status            String
  next_service_date DateTime?            @db.Date
  documentation_url String?
  image_url         String?
  last_updated      DateTime?            @default(now()) @db.Timestamp(6)
  last_changed_by   String?
  location          String?
  id                String               @id @default(dbgenerated("uuid_generate_v4()"))
  date_purchased    DateTime?            @db.Date
  notes             String?
  field_values      asset_field_values[]
  asset_logs        asset_logs[]
  users             users?               @relation("AssetAssignment", fields: [assigned_to_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  asset_types       asset_types?         @relation(fields: [type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  actions           asset_actions[]
  documents         asset_documents[]
  tasks             tasks[]              @relation("TaskAsset")

  // Indexes for the common list/filter/group-by paths (status summary,
  // inventory filters, per-user assignment lookups). FK columns are NOT
  // auto-indexed by Postgres, so these are added explicitly.
  @@index([type_id])
  @@index([status])
  @@index([assigned_to_id])
}

model asset_field_values {
  id                  String            @id @default(dbgenerated("uuid_generate_v4()"))
  asset_id            String
  asset_type_field_id String
  value               String?
  created_at          DateTime          @default(now()) @db.Timestamp(6)
  updated_at          DateTime          @updatedAt
  asset               assets            @relation(fields: [asset_id], references: [id], onDelete: Cascade)
  asset_type_field    asset_type_fields @relation(fields: [asset_type_field_id], references: [id], onDelete: NoAction)

  @@unique([asset_id, asset_type_field_id])
  @@index([asset_id])
  @@index([asset_type_field_id])
}

model asset_type_fields {
  id               String               @id @default(dbgenerated("uuid_generate_v4()"))
  asset_type_id    String
  field_type_id    String
  name             String
  slug             String
  description      String?
  is_required      Boolean              @default(false)
  default_value    String?
  options          Json?
  validation_rules Json?
  display_order    Int                  @default(0)
  created_at       DateTime             @default(now()) @db.Timestamp(6)
  updated_at       DateTime             @updatedAt
  field_values     asset_field_values[]
  asset_type       asset_types          @relation(fields: [asset_type_id], references: [id], onDelete: Cascade)
  field_type       field_types          @relation(fields: [field_type_id], references: [id], onDelete: NoAction)
  documents        asset_documents[]

  @@unique([asset_type_id, slug])
  @@index([asset_type_id])
}

// New: multiple attachments per asset
model asset_documents {
  id                   String            @id @default(dbgenerated("uuid_generate_v4()"))
  asset_id             String
  title                String?
  kind                 String?           // e.g., Service Report, Inspection Report
  related_date_label   String?
  related_date         DateTime?         @db.Date
  s3_key               String
  url                  String            // public or presigned origin URL at time of save
  content_type         String?
  size_bytes           Int?
  uploaded_by          String?
  created_at           DateTime          @default(now()) @db.Timestamp(6)
  deleted_at           DateTime?
  metadata             Json?
  asset_type_field_id  String?

  asset                assets            @relation(fields: [asset_id], references: [id], onDelete: Cascade)
  asset_type_field     asset_type_fields? @relation(fields: [asset_type_field_id], references: [id])

  @@index([asset_id, created_at])
  @@index([asset_type_field_id])
}

model field_types {
  id                String              @id @default(dbgenerated("gen_random_uuid()"))
  name              String
  slug              String              @unique
  description       String?
  has_options       Boolean             @default(false)
  validation_rules  Json?
  created_at        DateTime            @default(now()) @db.Timestamp(6)
  updated_at        DateTime            @updatedAt
  asset_type_fields asset_type_fields[]

  @@map("field_types")
}

model users {
  id                  String      @id @default(dbgenerated("uuid_generate_v4()"))
  name                String
  userassets          String[]
  /// Up to 3 asset-type names the user has pinned — each renders as its own
  /// quick-filter chip alongside "Needs service" on the Search / Inventory
  /// screen. Stored as type names (matching `assets.asset_type`) so the
  /// filter applies cleanly even if the underlying asset_types row is
  /// renamed; the chip will simply stop matching anything and the user can
  /// re-pick it.
  favourite_type_names String[]   @default([])
  useremail           String?     @unique
  role                UserRole    @default(USER)
  status              UserStatus  @default(ACTIVE)  // Account lifecycle status
  domain              String?     // Email domain, e.g. "engsurveys.com.au" — derived on write, used for scoped queries
  invitedById         String?     // FK to the admin who created the invitation
  expo_push_token     String?     // Expo push token for mobile task notifications
  created_at          DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?   @default(now()) @updatedAt @db.Timestamptz(6)

  // Self-relation: who invited this user
  invitedBy       users?      @relation("UserInvites", fields: [invitedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  invitees        users[]     @relation("UserInvites")

  asset_logs      asset_logs[]
  assets          assets[]    @relation("AssetAssignment")

  // Backrefs for action relations
  performed_actions asset_actions[] @relation("ActionPerformer")
  actions_from      asset_actions[] @relation("ActionFrom")
  actions_to        asset_actions[] @relation("ActionTo")

  // Backrefs for manual tasks
  tasks_assigned    tasks[]         @relation("TaskAssignee")
  tasks_created     tasks[]         @relation("TaskCreator")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE   // Registered and active
  INVITED  // Invited but not yet registered via Firebase
  DISABLED // Soft-deleted / suspended
}

// Structured record of actions performed on an asset
model asset_actions {
  id           String           @id @default(dbgenerated("uuid_generate_v4()"))
  asset_id     String
  type         AssetActionType
  data         Json?
  note         String?
  performed_by String?
  from_user_id String?
  to_user_id   String?
  occurred_at  DateTime         @default(now()) @db.Timestamp(6)

  asset     assets   @relation(fields: [asset_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  performer users?   @relation("ActionPerformer", fields: [performed_by], references: [id])
  from_user users?   @relation("ActionFrom", fields: [from_user_id], references: [id])
  to_user   users?   @relation("ActionTo", fields: [to_user_id], references: [id])
  details   asset_action_details?

  @@index([asset_id, occurred_at])
  @@index([type])
  // Activity feed / task queries filter by actor and transfer participants.
  @@index([performed_by])
  @@index([from_user_id])
  @@index([to_user_id])
  // Global activity feed orders by occurred_at across all assets.
  @@index([occurred_at])
}

// Optional structured details per action (1:1) to enable reporting
model asset_action_details {
  id              String           @id @default(dbgenerated("uuid_generate_v4()"))
  action_id       String           @unique
  action_type     AssetActionType
  // Common
  date            DateTime?        @db.Date
  notes           String?
  // Service (Repair/Maintenance)
  summary         String?
  estimated_cost  Decimal?         @db.Decimal(10, 2)
  priority        ActionPriority?
  // Hire
  hire_to         String?
  hire_start      DateTime?        @db.Date
  hire_end        DateTime?        @db.Date
  hire_rate       Decimal?         @db.Decimal(10, 2)
  hire_project    String?
  hire_client     String?
  // End of Life
  eol_reason      String?
  // Lost / Stolen
  where_location  String?
  police_report   String?

  action asset_actions @relation(fields: [action_id], references: [id], onDelete: Cascade)
}

// User-created (manual) tasks. Distinct from the computed task list (overdue
// dates / pending sign-offs): these are persisted with an explicit lifecycle
// (OPEN -> COMPLETED | DISMISSED). May be tied to an asset or stand alone.
model tasks {
  id             String    @id @default(dbgenerated("uuid_generate_v4()"))
  title          String
  description    String?
  category       String    @default("GENERAL") // GENERAL|SERVICE|REPAIR|MAINTENANCE|INSPECTION|CERTIFICATE|OTHER
  cert_type      String?    // sub-type when category=CERTIFICATE (e.g. Calibration, Test, Compliance)
  priority       String    @default("MEDIUM")  // LOW|MEDIUM|HIGH
  status         String    @default("OPEN")    // OPEN|COMPLETED|DISMISSED
  due_date       DateTime? @db.Date
  asset_id       String?
  assigned_to_id String?
  created_by     String?
  completed_by   String?
  completed_at   DateTime? @db.Timestamptz(6)
  completion_note String?  // details captured when the task is completed / signed off
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  asset    assets? @relation("TaskAsset", fields: [asset_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  assignee users?  @relation("TaskAssignee", fields: [assigned_to_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  creator  users?  @relation("TaskCreator", fields: [created_by], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([status])
  @@index([asset_id])
  @@index([assigned_to_id])
  @@index([due_date])
}

// Lightweight record of hard deletions for activity feed
model asset_deletions {
  id          String   @id @default(dbgenerated("uuid_generate_v4()"))
  asset_id    String
  deleted_at  DateTime @default(now()) @db.Timestamp(6)
  deleted_by  String?
  asset_name  String?
  asset_type  String?
  image_url   String?

  @@index([deleted_at])
}

/// Maps an organisation email domain (e.g. engsurveys.com.au) to the legal/display name used on hire signing audit PDFs and related flows.
model registered_domains {
  id           String   @id @default(dbgenerated("uuid_generate_v4()"))
  domain       String   @unique // normalised lowercase, e.g. engsurveys.com.au
  display_name String
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz(6)
}
