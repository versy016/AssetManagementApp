# Sentry error monitoring (optional but recommended for production)
# Create a project at https://sentry.io → grab the Node.js DSN
SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX

# Firebase Admin SDK (production only)
# Path to the service account JSON file on the server — never commit the file itself.
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key.
GOOGLE_APPLICATION_CREDENTIALS=/etc/gearops/firebase-service-account.json

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=your_region
S3_BUCKET=your_bucket_name
S3_USE_ACL=false
S3_ACL=public-read

# Database Configuration
DATABASE_URL=your_database_url

# Web app origin for QR check-in links (must be the site users open, not api.*).
# Used by /users/qr/* and matches server redirect logic (CHECKIN_WEB_BASE_URL).
# Production default in code is https://gearops.com.au if unset — set explicitly to avoid surprises.
CHECKIN_WEB_BASE_URL=https://gearops.com.au
# CHECKIN_BASE_URL=https://gearops.com.au

# BoldSign e-signature (optional — hire lease signing)
# Get your API key from BoldSign dashboard → Settings → API Keys
BOLDSIGN_API_KEY=your_boldsign_api_key_here

# BoldSign API region — only set if your account is on a non-US region.
# Australia (app-au.boldsign.com): https://api-au.boldsign.com
# EU (app-eu.boldsign.com):        https://api-eu.boldsign.com
# US / default:                    https://api.boldsign.com  (leave unset)
# BOLDSIGN_BASE_URL=https://api-au.boldsign.com

# BoldSign webhook HMAC secret (recommended for production, optional for local dev).
# Set up a webhook in BoldSign dashboard → point to https://api.gearops.com.au/hire-disclaimer/boldsign/webhook
# Copy the secret shown and paste here. Leave blank in dev (HMAC check is skipped when unset).
# BOLDSIGN_WEBHOOK_SECRET=your_webhook_hmac_secret

# ── Signature field placement ────────────────────────────────────────────────
#
# STRATEGY A — text tag (recommended if you can edit the Word template)
#   1. Open your hire lease .docx and put the text  {{{{Signature:sign_lease_1}}}}
#      exactly where you want the signature box to appear (e.g. on the "Signature:" line).
#   2. Set BOLDSIGN_USE_TEXT_TAGS=true here.
#   BoldSign finds that text in the document and replaces it with the interactive widget.
#   The signature box will land exactly where you typed the tag, regardless of page or position.
#
# BOLDSIGN_USE_TEXT_TAGS=true
#
# STRATEGY B — fixed coordinates (default — works without editing the Word template)
#   BoldSign places the signature box at the page + x/y position you set below.
#   Units are PDF points (72 pt = 1 inch).  For a typical A4 page (595 × 842 pt):
#     top-left is (0, 0), x increases right, y increases downward.
#     y=650 is about 77% down the page — adjust until the box lands on your signature line.
#
# BOLDSIGN_SIGN_PAGE=1
# BOLDSIGN_SIGN_X=50
# BOLDSIGN_SIGN_Y=650
# BOLDSIGN_SIGN_WIDTH=220
# BOLDSIGN_SIGN_HEIGHT=55
#
# Date field — defaults to immediately right of the signature box on the same row.
# BOLDSIGN_DATE_X=290      (auto: BOLDSIGN_SIGN_X + BOLDSIGN_SIGN_WIDTH + 20)
# BOLDSIGN_DATE_Y=650
# BOLDSIGN_DATE_WIDTH=150
# BOLDSIGN_DATE_HEIGHT=55

# Optional overrides:
# BOLDSIGN_EMAIL_SUBJECT=Please sign: Equipment hire lease
# BOLDSIGN_EMAIL_MESSAGE=Please review the attached Equipment Hire Lease document. Read the disclaimer and liability terms carefully, then click "Sign" to add your signature. Once signed, you will receive a completed copy automatically.

# Admin email that receives a completed copy when the lessee signs (CC recipient in BoldSign document).
# Set to empty string to disable. Defaults to admin@engsurveys.com.au if not set.
HIRE_ADMIN_CC_EMAIL=admin@engsurveys.com.au
# HIRE_ADMIN_CC_NAME=Engineering Surveys Admin

# Optional: UUID of an asset to attach "standalone" hires (no equipment ID on form) for PDF preview.
# If unset, the API uses the first empty placeholder asset (same rules as /assets/asset-options).
# HIRE_STANDALONE_ASSET_ID=

# Hire lease PDF preview: LibreOffice headless converts .docx → PDF (see inventory-api/docs/HIRE_PDF_PREVIEW.md)
# LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
# LIBREOFFICE_CONVERT_TIMEOUT_MS=120000

# Optional: absolute path to Equipment hire lease disclaimer .docx on this server.
# Use when deploy only includes inventory-api/ and not repo-root assets/Sheets/ (see hireDisclaimer findTemplatePath).
# HIRE_LEASE_TEMPLATE_PATH=/home/ec2-user/deploy/AssetManagementApp/assets/Sheets/Equipment hire lease disclaimer.docx

# Hire signing audit PDF: organisation display name is resolved from `registered_domains` using the
# email domain of the user who performed the hire (`asset_actions.performed_by`). Seed rows via SQL
# or Prisma. If no row matches, this fallback is used (optional).
# DEFAULT_SIGNING_OPERATING_ENTITY_NAME=Engineering Surveys

# Google Maps / Places (geocode on API + map in Expo app)
# Do not put EXPO_PUBLIC_API_URL in this file for Expo — only Google-related keys are read for the app bundle; other EXPO_PUBLIC_* here used to pollute Metro and break the API host.
# Server: places.js uses GOOGLE_PLACES_API_KEY or GOOGLE_MAPS_API_KEY for /places/geocode.
# Expo: app.config.js reads Google keys from this file only (Maps JavaScript API).
# Optional dedicated browser key; if unset, GOOGLE_MAPS_API_KEY or GOOGLE_PLACES_API_KEY is reused.
# GOOGLE_MAPS_WEB_KEY=AIza...
# GOOGLE_PLACES_API_KEY=AIza...
# GOOGLE_MAPS_API_KEY=AIza...
#
# Production (EAS / deployed web): inventory-api/.env is not on the EAS worker. Set the same
# variable names in expo.dev → Project → Environment variables (Production / Preview) so
# app.config.js sees process.env.* at build time, then run a new web build. Geocode: set these
# on the EC2/host process for inventory-api (PM2/systemd), not only in the Expo build.

# End of Life Admin Assignment
# Email of the admin user who should receive all End of Life assets
EOL_ADMIN_EMAIL=admin@abc.com
