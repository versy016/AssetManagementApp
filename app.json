{
  "expo": {
    "name": "GearOps",
    "slug": "gearops",
    "version": "1.0.5",
    "orientation": "portrait",
    "scheme": "gearops",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gearops.app",
      "associatedDomains": [
        "applinks:gearops.com.au",
        "applinks:www.gearops.com.au"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "This app uses the camera to scan QR codes for asset check-in and to take photos for assets.",
        "NSLocationWhenInUseUsageDescription": "We use your location to update an asset's last scanned location when you check it in or out.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      },
      "entitlements": {
        "com.apple.developer.associated-domains": [
          "applinks:gearops.com.au",
          "applinks:www.gearops.com.au"
        ]
      },
      "runtimeVersion": "1.0.5"
    },
    "android": {
      "package": "com.engsurveys.assetmanager",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "gearops.com.au",
              "pathPrefix": "/check-in"
            },
            {
              "scheme": "https",
              "host": "www.gearops.com.au",
              "pathPrefix": "/check-in"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "runtimeVersion": "1.0.5"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1E293B"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow the app to access your camera",
          "microphonePermission": "Allow the app to access your microphone",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#ffffff",
          "sounds": []
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2c66c30e-f54f-4ad4-b305-c05d4b35a9a5"
      }
    },
    "owner": "shivamsv19"
  }
}
